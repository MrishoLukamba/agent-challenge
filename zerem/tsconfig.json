{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["chrome", "vite/client"]
  },
  "include": ["src", "popup.html", "vite.config.ts", "src/vite-env.d.ts"]
}
